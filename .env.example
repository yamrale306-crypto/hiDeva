# ============================================================
# hiDeva — Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# DATABASE (required)
# ----------------------------------------------------------
# PostgreSQL connection string.
# Local:    postgresql://postgres:password@localhost:5432/hideva
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/hideva

# ----------------------------------------------------------
# SUPABASE
# ----------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------
# API SERVER
# ----------------------------------------------------------
# Port the Express server listens on (default: 8080)
PORT=8080

# Node environment: development | production | test
NODE_ENV=development

# Log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# ----------------------------------------------------------
# MOBILE APP (Expo)
# ----------------------------------------------------------
# Public API base URL — used by the mobile app to reach the server.
# Local development: http://localhost:8080
# Production:        https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://localhost:8080

# ----------------------------------------------------------
# VITE / WEB APP
# ----------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:8080

# ----------------------------------------------------------
# CONNECTOR KEYS
# ----------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
FIGMA_API_TOKEN=

# ----------------------------------------------------------
# SECURITY
# ----------------------------------------------------------
# A long random string used to sign sessions.
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string

# ----------------------------------------------------------
# OPTIONAL — REPLIT ONLY (not needed outside Replit)
# ----------------------------------------------------------
# These are set automatically by Replit. Remove or leave
# blank in all other environments.
# REPLIT_EXPO_DEV_DOMAIN=
# REPLIT_DEV_DOMAIN=
# REPL_ID=
