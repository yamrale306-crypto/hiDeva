{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "web:dev": "pnpm --filter @workspace/web run dev",
    "web:build": "pnpm --filter @workspace/web run build",
    "web:preview": "pnpm --filter @workspace/web run preview",
    "docker:up": "docker compose -f docker/docker-compose.yml up --build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./apps/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "@types/node": "^25.3.3"
  }
}
